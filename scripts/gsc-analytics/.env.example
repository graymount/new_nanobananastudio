# Google Search Console Analytics — Configuration
# Copy to .env and fill in values.

# Path to service account JSON key
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# GSC property URL
# For domain property:    sc-domain:nanobananastudio.com
# For URL-prefix property: https://nanobananastudio.com/
GSC_SITE_URL=sc-domain:nanobananastudio.com

# Date range (YYYY-MM-DD). Defaults: 90 days ago → 3 days ago.
# START_DATE=2025-12-01
# END_DATE=2026-03-01

# Brand terms (comma-separated, case-insensitive)
BRAND_TERMS=nano banana,nanobanana,nano-banana,nanobananastudio

# Keyword seeds for cluster highlighting (comma-separated)
CLUSTER_SEEDS=text rendering,misspelling,blurry text,typography,diffusion text,font,lettering,readable,ocr

# Output directory
OUTPUT_DIR=./output

# Max rows per report (default: 5000)
MAX_ROWS=5000

# Rows to show in report tables (default: 30)
TOP_N=30
